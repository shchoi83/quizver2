    let content = `<span class="q-title">${i + 1}. ${item.q}</span>`;
    content += `<ul class="options">`;
    item.o.forEach((opt, oi) => {
        content += `
            <li onclick="const cb = document.getElementById('q${i}_${oi}'); cb.checked = !cb.checked;">
                <input type="checkbox" name="q${i}" id="q${i}_${oi}" value="${oi}" onclick="event.stopPropagation();">
                <label for="q${i}_${oi}">${oi + 1}) ${opt}</label>
            </li>`;
    });
    content += `</ul><div id="ans${i}" class="ans-box">정답 번호: <b>${item.a.map(v=>v+1).join(', ')}</b></div>`;
    div.innerHTML = content;
    container.appendChild(div);
});

function checkAnswers() {
    let score = 0;
    let wrongs = [];
    data.forEach((item, i) => {
        const checked = Array.from(document.querySelectorAll(`input[name="q${i}"]:checked`)).map(el => parseInt(el.value));
        const isCorrect = JSON.stringify(checked.sort()) === JSON.stringify(item.a.sort());
        const card = document.getElementById(`card-${i}`);
        const ansBox = document.getElementById(`ans${i}`);
        ansBox.style.display = "block";
        if (isCorrect) { score++; card.className = 'q-card correct-card'; } 
        else { wrongs.push(i + 1); card.className = 'q-card wrong-card'; }
    });
    document.getElementById('result-area').style.display = 'block';
    document.getElementById('score-val').innerText = score;
    document.getElementById('wrong-numbers').innerText = wrongs.length > 0 ? wrongs.join(', ') : "없음! 완벽해요.";
    window.scrollTo(0, 0);
}
</script>
</body>
